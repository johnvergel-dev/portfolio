# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored. On Vercel, set these in Project Settings → Environment Variables.
# ---------------------------------------------------------------------------

# GitHub fine-grained Personal Access Token (read-only) for the live
# GITHUB.FEED module. It raises the rate limit to 5,000/h and is read ONLY on
# the server (never exposed to the client). The site works WITHOUT it too —
# it falls back to unauthenticated REST (60/h) and shows a discreet banner.
#
# Create one at: https://github.com/settings/personal-access-tokens
#   • Resource owner: your account
#   • Repository access: Public repositories (read-only)
#   • Account permissions: none required (public profile data is enough)
GITHUB_TOKEN=

# Absolute production URL used for canonical links, Open Graph and sitemap.
# Vercel auto-detects its own URL, so this is only needed for a custom domain.
#   e.g. https://yourname.dev
NEXT_PUBLIC_SITE_URL=
